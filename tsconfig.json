{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2020"],
    "outDir": "./out",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node16",
     "types": ["node", "vscode", "jest"],
    "jsx": "react"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "out", "webview", "src/storage/imageWorker.ts"]
}